{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "https://codeberg.org/margau/renovate-defaults/raw/branch/main/default.json"
  ],
  "packageRules": [
    {
      "matchFileNames": [
        ".forgejo/workflows/commitlint.yaml",
        ".forgejo/workflows/lint.yaml",
        ".forgejo/workflows/test.yaml",
        ".forgejo/workflows/publish.yaml",
        ".forgejo/workflows/container.yaml",
        "Containerfile"
      ],
      "enabled": false
    },
    {
      "matchFileNames": [
        ".forgejo/workflows/commitlint.yaml",
        ".forgejo/workflows/lint.yaml",
        ".forgejo/workflows/test.yaml",
        ".forgejo/workflows/publish.yaml",
        ".forgejo/workflows/container.yaml",
        "Containerfile"
      ],
      "matchManagers": [
        "copier"
      ],
      "enabled": true
    },
    {
      "matchManagers": [
        "docker-compose"
      ],
      "matchUpdateTypes": [
        "pin",
        "digest"
      ],
      "enabled": false
    },
    {
      "matchPackageNames": [
          "ruff",
          "pylint",
          "pytest",
          "coverage"
      ],
      "matchFileNames": [
        "pyproject.toml"
      ],
      "enabled": false
    },
    {
      "matchManagers": [
        "copier"
      ],
      "separateMinorPatch": true,
      "ignoreScripts": false,
      "postUpgradeTasks": {
        "commands": ["uv lock"],
        "executionMode": "branch"
      }
    },
    {
      "matchUpdateTypes": [
        "patch",
        "digest"
      ],
      "matchPackageNames": ["codeberg.org/margau/buildenv*", "https://codeberg.org/margau/copier-python-uv.git"],
      "groupName": "housekeeping",
      "automerge": true,
      "automergeSchedule": "* 0-3 */2 * *"
    }
  ]
}
